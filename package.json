{
  "name": "indiefilmer",
  "version": "0.1.0",
  "description": "A self-hosted film production planner for microbudget filmmakers",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "prebuild": "tsx scripts/prisma-provider.ts && prisma generate",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:set-provider": "tsx scripts/prisma-provider.ts",
    "setup": "bash setup.sh",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mdx-js/mdx": "^3.1.1",
    "@prisma/client": "^5.17.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/nextjs": "^8.55.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.441.0",
    "next": "^16.1.6",
    "puppeteer": "^24.37.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.2",
    "eslint-config-next": "^0.2.4",
    "postcss": "^8.4.38",
    "prisma": "^5.17.0",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
