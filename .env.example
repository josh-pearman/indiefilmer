# Database URL (SQLite default; set to postgresql://... for VPS deployment)
DATABASE_URL="file:../data/db.sqlite"

# Auth mode: "password" (self-hosted) or "email" (public VPS)
AUTH_MODE=password

# Chat mode: "off", "cli" (Claude CLI), or "api" (Anthropic SDK)
CHAT_MODE=off

# Required when CHAT_MODE=api
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google Maps for locations + call sheets
# GOOGLE_MAPS_API_KEY=AIza...

# Optional: Resend API key — enables direct email sending for intake forms.
# Also required when AUTH_MODE=email (login codes + invites).
# Free tier: 100 emails/day, 3k/month. Get a key at https://resend.com
# RESEND_API_KEY=re_...

# Required when AUTH_MODE=email
# SUPERADMIN_EMAIL=you@example.com

# Base URL for invite links and emails
# APP_URL=http://localhost:3001

# Email sender address (used when RESEND_API_KEY is set)
# RESEND_FROM_EMAIL=hello@yourdomain.com

# Per-project storage quota in MB (default: 500)
# PROJECT_STORAGE_QUOTA_MB=500
